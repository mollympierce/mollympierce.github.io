---
import BaseLayout from '@layouts/BaseLayout.astro';

const title = "Molly Pierce Design";
const description = "";
const bodyClass = "";
---
<BaseLayout
  title={title}
  description={description}
  bodyClass={bodyClass}
>
  <div>
    <div class="w-row">
      <div class="main-left w-col w-col-3"></div>
      <div class="main right-side w-col w-col-9">
        <div class="div-block-80">
          <h1 class="heading-98">Project Archive</h1>
          <div class="w-dyn-list">
            <div role="list" class="collection-list-29 w-dyn-items">
              <div role="listitem" class="w-dyn-item">
                <a
                  href="/portfolio-categories/molly-pierce-design-freelance-projects-2014-2022"
                  class="tag-2 w-button"
                >
                  Client Work
                </a>
              </div>
              <div role="listitem" class="w-dyn-item">
                <a
                  href="/portfolio-categories/back-to-school-22-23-class-projects-university-of-texas-at-austin-school-of-creative-technology-design"
                  class="tag-2 w-button"
                >
                  Personal/School Projects
                </a>
              </div>
            </div>
          </div>
          <div class="tag-wrapper w-dyn-list">
            <div role="list" class="tag-list w-dyn-items">
              <div role="listitem" class="w-dyn-item">
                <a href="/tags/3d" class="tag w-button">3D</a>
              </div>
              <div role="listitem" class="w-dyn-item">
                <a
                  href="/tags/motion-graphics"
                  aria-current="page"
                  class="tag w-button w--current"
                >
                  Motion Graphics
                </a>
              </div>
              <div role="listitem" class="w-dyn-item">
                <a href="/tags/poster-design" class="tag w-button">Poster</a>
              </div>
              <div role="listitem" class="w-dyn-item">
                <a href="/tags/typography" class="tag w-button">Typography</a>
              </div>
              <div role="listitem" class="w-dyn-item">
                <a href="/tags/logo-design" class="tag w-button">Logo</a>
              </div>
              <div role="listitem" class="w-dyn-item">
                <a href="/tags/branding" class="tag w-button">Branding</a>
              </div>
              <div role="listitem" class="w-dyn-item">
                <a href="/tags/illustration" class="tag w-button">Illustration</a>
              </div>
              <div role="listitem" class="w-dyn-item">
                <a href="/tags/signage-environmental-design" class="tag w-button">
                  Environmental
                </a>
              </div>
              <div role="listitem" class="w-dyn-item">
                <a href="/tags/newsletter-design" class="tag w-button">
                  Newsletter
                </a>
              </div>
              <div role="listitem" class="w-dyn-item">
                <a href="/tags/editorial-design" class="tag w-button">
                  Editorial
                </a>
              </div>
              <div role="listitem" class="w-dyn-item">
                <a href="/tags/print-design" class="tag w-button">Print</a>
              </div>
              <div role="listitem" class="w-dyn-item">
                <a href="/tags/event-branding" class="tag w-button">Events</a>
              </div>
              <div role="listitem" class="w-dyn-item">
                <a href="/tags/website-design" class="tag w-button">
                  Website Design
                </a>
              </div>
              <div role="listitem" class="w-dyn-item">
                <a href="/tags/web-design" class="tag w-button">Website</a>
              </div>
              <div role="listitem" class="w-dyn-item">
                <a href="/tags/interviews" class="tag w-button">Interviews</a>
              </div>
              <div role="listitem" class="w-dyn-item">
                <a href="/tags/featured" class="tag w-button">Featured</a>
              </div>
            </div>
          </div>
        </div>
        <div class="w-dyn-list">
          <div role="list" class="collection-list-28 w-dyn-items">
            <div role="listitem" class="collection-item-21 w-dyn-item">
              <div>
                <div class="div-block-42">
                  <div class="portfolio-number">
                    <h3 class="heading-81">0</h3>
                    <h3 class="heading-81">1</h3>
                  </div>
                </div>
                <a
                  href="/tags/motion-graphics"
                  class="portfolio-link w-inline-block"
                >
                  <img
                    src="/assets/images/tree.jpg"
                    loading="lazy"
                    alt=""
                    sizes="(max-width: 479px) 43vw, (max-width: 767px) 45vw, (max-width: 991px) 46vw, 33vw"
                    srcset="
                      /assets/images/tree-p-500.jpg   500w,
                      /assets/images/tree-p-800.jpg   800w,
                      /assets/images/tree-p-1080.jpg 1080w,
                      /assets/images/tree-p-1600.jpg 1600w,
                      /assets/images/tree.jpg        1920w
                    "
                    class="portfolio-img"
                  />
                </a>
                <div class="div-block-42 portfolio-row">
                  <a
                    href="/portfolio-item/the-grateful-ghost"
                    class="div-block-43 w-inline-block"
                  >
                    <h6>The Grateful Ghost</h6>
                  </a>
                  <a
                    href="/portfolio-categories/back-to-school-22-23-class-projects-university-of-texas-at-austin-school-of-creative-technology-design"
                    class="div-block-43 w-inline-block"
                  >
                    <h6 class="heading-84 tag tag2">Personal/School Projects</h6>
                  </a>
                </div>
                <div class="div-block-42 portfolio-row portfolio-row-btm">
                  <div class="div-block-63">
                    <div class="tag-wrapper w-dyn-list">
                      <div role="list" class="tag-list w-dyn-items">
                        <div role="listitem" class="w-dyn-item">
                          <a href="/tags/motion-graphics" class="tag w-button">
                            Illustration
                          </a>
                        </div>
                        <div role="listitem" class="w-dyn-item">
                          <a href="/tags/motion-graphics" class="tag w-button">
                            Motion Graphics
                          </a>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="div-block-44">
                    <p class="paragraph-16">
                      1-minute otherworldly ‘animatic’ inspired by a Korean
                      parable.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div
            role="navigation"
            aria-label="List"
            class="w-pagination-wrapper pagination"
          ></div>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>
