---
import BaseLayout from '@layouts/BaseLayout.astro';
import SiteHeader from '@components/SiteHeader.astro';
import SiteFooter from '@components/SiteFooter.astro';
---
<BaseLayout>
  <SiteHeader />
  <main>
    <section class="section hero">
      <div class="container">
        <p class="eyebrow">Archived site rebuild</p>
        <h1>Molly Pierce Design</h1>
        <p class="intro">This Astro site is prepared as the replacement shell for the recovered archive of mollypiercedesign.com. Content and assets should be populated from the most recent Wayback capture, with older captures used only to fill missing pages.</p>
      </div>
    </section>

    <section id="work" class="section">
      <div class="container">
        <p class="eyebrow">Work</p>
        <h2>Recovered portfolio</h2>
        <div class="grid grid-3 cards">
          <article class="card"><h3>Project</h3><p>Replace this placeholder with recovered archive content.</p></article>
          <article class="card"><h3>Project</h3><p>Images belong in <code>public/assets</code> with archive source notes.</p></article>
          <article class="card"><h3>Project</h3><p>Old URLs can be preserved with matching Astro page routes.</p></article>
        </div>
      </div>
    </section>

    <section id="about" class="section alt">
      <div class="container narrow">
        <p class="eyebrow">About</p>
        <h2>Design archive, cleaned up for static hosting.</h2>
        <p>This is intentionally structured as maintainable Astro instead of a raw HTML dump. The old site can be restored page-by-page while keeping deployment simple.</p>
      </div>
    </section>

    <section id="contact" class="section">
      <div class="container narrow">
        <p class="eyebrow">Contact</p>
        <h2>Contact details pending archive recovery.</h2>
        <p>After the archive scrape is available, replace this copy with the latest recovered contact information.</p>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
<style>
  .hero { padding-top: clamp(4rem, 10vw, 8rem); }
  .intro { max-width: 48rem; font-size: clamp(1.1rem, 2vw, 1.35rem); }
  .cards { margin-top: 2rem; }
  .narrow { max-width: 760px; }
  .alt { background: rgba(255,255,255,.28); border-block: 1px solid var(--line); }
  code { font-size: .9em; }
</style>
