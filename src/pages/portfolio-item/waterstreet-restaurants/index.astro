        <div class="portfolio-slide">
          <img
            src="/assets/images/surf-club-elements.png"
            loading="lazy"
            alt=""
            sizes="(max-width: 767px) 100vw, 75vw"
            srcset="
              /assets/images/surf-club-elements-p-500.png   500w,
              /assets/images/surf-club-elements-p-800.png   800w,
              /assets/images/surf-club-elements-p-1080.png 1080w,
              /assets/images/surf-club-elements.png        1600w
            "
          />
        </div>
        <div class="portfolio-slide">
          <img
            src="/assets/images/screen-shot-2022-12-21-at-8.26.25-pm.png"
            loading="lazy"
            alt=""
            sizes="(max-width: 767px) 100vw, 75vw"
            srcset="
              /assets/images/screen-shot-2022-12-21-at-8.26.25-pm-p-500.png   500w,
              /assets/images/screen-shot-2022-12-21-at-8.26.25-pm-p-800.png   800w,
              /assets/images/screen-shot-2022-12-21-at-8.26.25-pm-p-1080.png 1080w,
              /assets/images/screen-shot-2022-12-21-at-8.26.25-pm-p-1600.png 1600w,
              /assets/images/screen-shot-2022-12-21-at-8.26.25-pm.png        1656w
            "
          />
        </div>
        <div class="portfolio-slide">
          <img
            src="/assets/images/mpd-kids-menu-executive-surf-club.png"
            loading="lazy"
            alt=""
            sizes="100vw"
            srcset="
              /assets/images/mpd-kids-menu-executive-surf-club-p-500.png   500w,
              /assets/images/mpd-kids-menu-executive-surf-club-p-800.png   800w,
              /assets/images/mpd-kids-menu-executive-surf-club-p-1080.png 1080w,
              /assets/images/mpd-kids-menu-executive-surf-club.png        1454w
            "
            class="image-38"
          />
        </div>
        <div class="portfolio-slide">
          <img
            src="/assets/images/img-1914.jpg"
            loading="lazy"
            alt=""
            sizes="100vw"
            srcset="
              /assets/images/img-1914-p-500.jpg   500w,
              /assets/images/img-1914-p-800.jpg   800w,
