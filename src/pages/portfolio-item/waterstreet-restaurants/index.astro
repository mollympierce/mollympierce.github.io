          />
        </div>
        <div class="portfolio-slide">
          <img
            src="/assets/images/surf-club-e1529275664748.png"
            loading="lazy"
            alt=""
            sizes="100vw"
            srcset="
              /assets/images/surf-club-e1529275664748-p-500.png   500w,
              /assets/images/surf-club-e1529275664748-p-800.png   800w,
              /assets/images/surf-club-e1529275664748-p-1080.png 1080w,
              /assets/images/surf-club-e1529275664748.png        1396w
