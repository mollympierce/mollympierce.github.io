          />
        </div>
        <div class="portfolio-slide">
          <img
            src="/assets/images/mpd-surf-museum-ipad-pink.jpg"
            loading="lazy"
            alt=""
            sizes="100vw"
            srcset="
              /assets/images/mpd-surf-museum-ipad-pink-p-500.jpg   500w,
              /assets/images/mpd-surf-museum-ipad-pink-p-800.jpg   800w,
              /assets/images/mpd-surf-museum-ipad-pink-p-1080.jpg 1080w,
              /assets/images/mpd-surf-museum-ipad-pink.jpg        1600w
            "
          />
        </div>
      </div>
    </div>
  </div>

</BaseLayout>
