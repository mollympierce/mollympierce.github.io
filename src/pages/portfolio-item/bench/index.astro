              /assets/images/screen-shot-2022-12-21-at-3.01.10-pm-p-500.png   500w,
              /assets/images/screen-shot-2022-12-21-at-3.01.10-pm-p-800.png   800w,
              /assets/images/screen-shot-2022-12-21-at-3.01.10-pm-p-1080.png 1080w,
              /assets/images/screen-shot-2022-12-21-at-3.01.10-pm-p-1600.png 1600w,
              /assets/images/screen-shot-2022-12-21-at-3.01.10-pm.png        1742w
            "
          />
        </div>
        <div class="portfolio-slide"></div>
        <div class="portfolio-slide"></div>
        <div class="portfolio-slide"></div>
        <div class="portfolio-slide"></div>
      </div>
    </div>
  </div>

</BaseLayout>
