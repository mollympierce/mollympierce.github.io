            alt=""
            sizes="(max-width: 767px) 100vw, 75vw"
            srcset="
              /assets/images/bench5-p-500.png   500w,
              /assets/images/bench5-p-800.png   800w,
              /assets/images/bench5-p-1080.png 1080w,
              /assets/images/bench5-p-1600.png 1600w,
              /assets/images/bench5.png        1634w
            "
          />
        </div>
        <div class="portfolio-slide">
          <img
            src="/assets/images/screen-shot-2022-12-21-at-3.01.10-pm.png"
            loading="lazy"
            alt=""
            sizes="(max-width: 767px) 100vw, 75vw"
