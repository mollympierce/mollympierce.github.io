---
import BaseLayout from '@layouts/BaseLayout.astro';

const title = "Molly Pierce Design";
const description = "";
const bodyClass = "";
const pageStyles = "\n  body {\n  -moz-font-feature-settings: \"liga\" on;\n  -moz-osx-font-smoothing: grayscale;\n  -webkit-font-smoothing: antialiased;\n  font-feature-settings: \"liga\" on;\n  text-rendering: optimizeLegibility;\n}\n";
---
<BaseLayout
  title={title}
  description={description}
  bodyClass={bodyClass}
  pageStyles={pageStyles}
>
  <div>
    <div class="w-row">
      <div class="column-25 portfolio-page w-col w-col-9">
        <div class="portfolio-top">
          <div class="portfolio-top-left">
            <div class="portfolio-text">
              <div>
                <div class="portfolio-text--line">
                  <h4 class="portfolio-title">Woolsey &amp; Woolsey</h4>
                  <a
                    href="/portfolio-categories/molly-pierce-design-freelance-projects-2014-2022"
                    class="tag-2 w-button"
                  >
                    Client Work
                  </a>
                </div>
              </div>
              <div>
                <div class="tag-wrapper w-dyn-list">
                  <div role="list" class="tag-list w-dyn-items">
                    <div role="listitem" class="w-dyn-item">
                      <a
                        href="/portfolio-item/woolsey-woolsey"
                        class="tag w-button"
                      >
                        Website
                      </a>
                    </div>
                  </div>
                </div>
                <p class="portfolio-caption">
                  Website design for small family-owned law group.
                </p>
                <h6 class="heading-123 w-condition-invisible">What I did:</h6>
              </div>
            </div>
            <a
              href="/portfolio-categories/molly-pierce-design-freelance-projects-2014-2022"
              class="back-link w-inline-block"
            >
              <h6 class="back-btn">↖ BACK</h6>
            </a>
            <a
              href="/portfolio-categories/molly-pierce-design-freelance-projects-2014-2022"
              class="w-inline-block w-condition-invisible"
            >
              <h6 class="heading-121 w-dyn-bind-empty"></h6>
              <h6 class="heading-122">↗</h6>
            </a>
          </div>
          <div
            style="
              background-image: url(/assets/images/mpd-woolsey-website-3.jpg);
            "
            class="portfolio-top-right"
          ></div>
        </div>
        <div class="portfolio-slide">
          <img
            src="/assets/images/law1.jpg"
            loading="lazy"
            alt=""
            sizes="(max-width: 767px) 100vw, 75vw"
            srcset="
              /assets/images/law1-p-500.jpg   500w,
              /assets/images/law1-p-800.jpg   800w,
              /assets/images/law1-p-1080.jpg 1080w,
              /assets/images/law1-p-1600.jpg 1600w,
              /assets/images/law1-p-2000.jpg 2000w,
              /assets/images/law1.jpg        2400w
            "
          />
        </div>
        <div class="portfolio-slide">
          <img
            src="/assets/images/macbook-air.jpg"
            loading="lazy"
            alt=""
            sizes="(max-width: 767px) 100vw, 75vw"
            srcset="
              /assets/images/macbook-air-p-500.jpg   500w,
              /assets/images/macbook-air-p-800.jpg   800w,
              /assets/images/macbook-air-p-1080.jpg 1080w,
              /assets/images/macbook-air-p-1600.jpg 1600w,
              /assets/images/macbook-air-p-2000.jpg 2000w,
              /assets/images/macbook-air.jpg        2400w
            "
          />
        </div>
        <div class="portfolio-slide">
          <img
            src="/assets/images/mpd-woolsey-website-1.jpg"
            loading="lazy"
            alt=""
            sizes="(max-width: 767px) 100vw, 75vw"
            srcset="
              /assets/images/mpd-woolsey-website-1-p-500.jpg   500w,
              /assets/images/mpd-woolsey-website-1-p-800.jpg   800w,
              /assets/images/mpd-woolsey-website-1-p-1080.jpg 1080w,
              /assets/images/mpd-woolsey-website-1.jpg        1400w
            "
          />
        </div>
        <div class="portfolio-slide"></div>
        <div class="portfolio-slide"></div>
        <div class="portfolio-slide"></div>
        <div class="portfolio-slide"></div>
        <div class="portfolio-slide"></div>
        <div class="portfolio-slide"></div>
      </div>
    </div>
  </div>

</BaseLayout>
